# AutoDev Crew environment
# Optional for local CLI runs only.
# The public Gradio dashboard requires each user to paste their own OpenAI API key in the UI before generation.
# Do not hardcode a real key before deploying publicly.
OPENAI_API_KEY=

# Optional local dashboard configuration.
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860

# Optional: set to 1 for verbose local debugging in custom extensions.
AUTODEV_DEBUG=0
