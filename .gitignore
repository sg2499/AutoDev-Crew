# ============================================================
# AutoDev Crew - .gitignore
# Keeps local secrets, environments, generated outputs, caches,
# deployment artifacts, and temporary files out of Git.
# ============================================================


# ============================================================
# Secrets / Environment Variables
# ============================================================

.env
.env.*
!.env.example
.envrc


# ============================================================
# Python bytecode / optimized / DLL files
# ============================================================

__pycache__/
*.py[cod]
*$py.class
*.pyd
*.pyo


# ============================================================
# C extensions
# ============================================================

*.so


# ============================================================
# Virtual environments
# ============================================================

.venv/
venv/
env/
ENV/
env.bak/
venv.bak/


# ============================================================
# AutoDev Crew generated outputs
# ============================================================

output/
outputs/
generated/
generated_projects/
generated_project_runs/
*.zip
*.tar.gz
*.7z
*.rar


# ============================================================
# Local runtime / temporary / backup files
# ============================================================

*.tmp
*.temp
*.bak
*.backup
*.old
*.log
*.jsonl
tempCodeRunnerFile.py


# ============================================================
# Local databases / state files
# ============================================================

*.sqlite
*.sqlite3
*.db
db.sqlite3
db.sqlite3-journal


# ============================================================
# Hugging Face / Gradio local artifacts
# ============================================================

.huggingface/
gradio_cached_examples/
flagged/
logs/


# ============================================================
# Distribution / packaging
# ============================================================

.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST


# ============================================================
# PyInstaller
# ============================================================

*.manifest
*.spec


# ============================================================
# Installer logs
# ============================================================

pip-log.txt
pip-delete-this-directory.txt


# ============================================================
# Unit test / coverage reports
# ============================================================

htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache/
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/


# ============================================================
# Type checker / linter / formatter caches
# ============================================================

.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/


# ============================================================
# Jupyter / IPython
# ============================================================

.ipynb_checkpoints/
profile_default/
ipython_config.py


# ============================================================
# PEP 582 / local package stores
# ============================================================

__pypackages__/


# ============================================================
# UV / Poetry / PDM / Pixi
# ============================================================

# Keep uv.lock committed for reproducible installs.
# uv.lock

# Poetry lock files are usually committed for apps.
# poetry.lock
# poetry.toml

.pdm-python
.pdm-build/
.pixi/


# ============================================================
# Django / Flask / Scrapy / Web framework artifacts
# ============================================================

local_settings.py
instance/
.webassets-cache/
.scrapy/


# ============================================================
# Sphinx / MkDocs documentation builds
# ============================================================

docs/_build/
/site/


# ============================================================
# Celery / Redis / RabbitMQ / ActiveMQ
# ============================================================

celerybeat-schedule
celerybeat.pid
*.rdb
*.aof
*.pid
mnesia/
rabbitmq/
rabbitmq-data/
activemq-data/


# ============================================================
# Translations
# ============================================================

*.mo
*.pot


# ============================================================
# SageMath parsed files
# ============================================================

*.sage.py


# ============================================================
# Marimo
# ============================================================

marimo/_static/
marimo/_lsp/
__marimo__/


# ============================================================
# Streamlit secrets
# ============================================================

.streamlit/secrets.toml


# ============================================================
# Editor / IDE files
# ============================================================

# VS Code
.vscode/

# JetBrains / PyCharm
.idea/

# Spyder
.spyderproject
.spyproject

# Rope
.ropeproject


# ============================================================
# OS clutter
# ============================================================

.DS_Store
Thumbs.db
Desktop.ini


# ============================================================
# Media files that are usually too large for Git
# Keep compressed screenshots/assets if needed, but ignore videos.
# ============================================================

*.mp4
*.mov
*.avi
*.mkv
*.webm
